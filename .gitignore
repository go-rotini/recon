# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# Local dev .env files MUST never be committed.
# Test fixtures under testdata/ are tracked; the negation below preserves them.
.env
.env.*
!.env.example
!testdata/

# Editor/IDE
# .idea/
# .vscode/

# macOS Finder metadata
.DS_Store

# Mutation testing output
test_mutation.json
